# ====================================================================
# Python
# ====================================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
.venv/
venv/
env/
.python-version

# ====================================================================
# Jupyter
# ====================================================================
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# ====================================================================
# Data — 절대 커밋 금지 (용량/저작권/민감)
#   data/ 안의 모든 csv, parquet, xlsx 등은 git 추적 X
#   .gitkeep만 남겨 디렉터리 구조 유지
# ====================================================================
data/raw/*
data/interim/*
data/processed/*
!data/raw/.gitkeep
!data/interim/.gitkeep
!data/processed/.gitkeep

# ====================================================================
# Models — 학습된 가중치는 커밋 금지 (Git LFS 대안)
# ====================================================================
models/*
!models/.gitkeep
*.h5
*.pkl
*.joblib
*.pt
*.pth
*.ckpt

# ====================================================================
# Environment / Secrets — API 키 절대 커밋 금지
# ====================================================================
.env
.env.local
.env.*.local
*.key

# ====================================================================
# Logs
# ====================================================================
*.log
nb*_log.txt
data/collection_log.txt

# ====================================================================
# IDE / OS
# ====================================================================
.vscode/
.idea/
*.swp
.DS_Store
Thumbs.db
desktop.ini

# ====================================================================
# Streamlit
# ====================================================================
.streamlit/secrets.toml

# ====================================================================
# Cloudinary — API secret 평문 포함, 커밋 금지 (rotate 권장)
# ====================================================================
scripts/cloudinary_upload_charts.py
scripts/cloudinary_urls.json
scripts/_cloud_relabel_urls.json

# ====================================================================
# 임시 검증·미리보기 파일
# ====================================================================
scripts/_*.py
app/_forecast_log.txt
_*.png
reports/figures/**/_preview_*.png
